{
  "manifest_version": 3,
  "name": "Anti-Procrastination",
  "version": "2.1",
  "permissions": ["storage", "alarms", "notifications", "tabs"],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}